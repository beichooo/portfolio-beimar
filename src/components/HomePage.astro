                            target="_blank"
                            class="bg-slate-800 text-slate-200 border border-slate-700 font-semibold py-2 px-4 rounded-lg text-sm hover:border-sky-400/60 hover:text-sky-400 transition-colors duration-300 inline-flex items-center"
                        >
                            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.168 6.839 9.492.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.031-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.03 1.595 1.03 2.688 0 3.848-2.338 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.001 10.001 0 0022 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd"></path></svg>
                            Ver Código
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección de Habilidades (Bento) -->
        <section id="skills" class="py-20">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-slate-50 mb-12 reveal">
                Habilidades Clave
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-6 md:auto-rows-[minmax(180px,auto)] gap-4 md:gap-6">
                <!-- Stack técnico (anchor) -->
                <div class="md:col-span-4 md:row-span-2 bg-slate-900 border border-slate-800 rounded-2xl p-7 md:p-8 transition-all duration-300 hover:border-orange-500/50 reveal">
                    <h3 class="font-display text-2xl font-bold text-slate-50 mb-6">
                        Stack Técnico & IA
                    </h3>
                    <ul class="grid grid-cols-2 lg:grid-cols-3 gap-3 text-slate-300">
                        <li class="flex items-center">
                            <svg class="w-5 h-5 mr-2 text-sky-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Python (Django)
                        </li>
                        <li class="flex items-center">
                            <svg class="w-5 h-5 mr-2 text-sky-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
