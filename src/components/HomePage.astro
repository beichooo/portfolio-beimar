---
import ScrollReveal from './ScrollReveal.astro';
---

<div class="container mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <!-- Header y Navegación -->
    <header class="flex justify-between items-center py-6 sticky top-0 bg-slate-950/70 backdrop-blur-md z-20 border-b border-slate-900">
        <div class="text-2xl font-bold font-display tracking-tight">
            <a href="#" class="bg-gradient-to-r from-orange-400 to-sky-400 text-gradient">BCL</a>
        </div>
        <nav class="hidden md:flex space-x-8 text-base font-medium text-slate-300">
            <a href="#projects" class="hover:text-orange-400 transition-colors">Proyectos Tech</a>
            <a href="#skills" class="hover:text-orange-400 transition-colors">Habilidades</a>
            <a href="#case-studies" class="hover:text-orange-400 transition-colors">Marketing</a>
            <a href="#contact" class="hover:text-orange-400 transition-colors">Contacto</a>
        </nav>
    </header>

    <main>
        <!-- Sección Principal (Hero) -->
        <section id="home" class="py-16 md:py-32 reveal">
            <div class="flex flex-col md:flex-row items-center justify-between gap-12">
                <!-- Columna de imagen -->
                <div class="md:w-2/5 flex justify-center md:justify-end">
                    <img
                        src="./photo-pro-cropped 2.png"
                        alt="Foto de Beymar Chipana"
                        class="w-64 h-64 md:w-80 md:h-80 rounded-full object-cover ring-2 ring-orange-500/40 shadow-[0_0_60px_-15px_rgba(249,115,22,0.5)]"
                    />
                </div>
                <!-- Columna de texto -->
                <div class="md:w-3/5 text-center md:text-left">
                    <h1 class="font-display text-4xl md:text-6xl font-extrabold tracking-tight text-slate-50 mb-4">
                        Beymar Chipana Lucana
                    </h1>
                    <p class="text-2xl md:text-3xl font-semibold bg-gradient-to-r from-orange-400 to-sky-400 text-gradient mb-8">
                        Desarrollador y Estratega Digital
                    </p>
                    <p class="text-lg md:text-xl text-slate-400 mb-10">
                        Construyo soluciones de software y aplico mi conocimiento de marketing para crear beneficios estratégicos
                    </p>
                    <a
                        href="https://wa.me/59178780972" target="_blank"
                        class="bg-orange-500 hover:bg-orange-400 text-white font-bold py-3 px-8 rounded-lg text-lg shadow-lg shadow-orange-500/25 transition-transform duration-300 inline-block transform hover:scale-105"
                    >
                        Hablemos
                    </a>
                </div>
            </div>
        </section>

        <!-- Proyectos de Desarrollo e IA -->
        <section id="projects" class="py-20">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-slate-50 mb-12 reveal">
                Proyectos de Desarrollo e IA
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-6 md:auto-rows-[minmax(220px,auto)] gap-4 md:gap-6">
                <!-- Proyecto PASY (flagship) -->
                <div class="md:col-span-4 md:row-span-2 group relative bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden flex flex-col p-7 md:p-8 transition-all duration-300 hover:border-orange-500/50 hover:-translate-y-1 reveal">
                    <div class="w-14 h-14 rounded-xl bg-orange-500/10 border border-orange-500/20 text-orange-400 flex items-center justify-center mb-5 group-hover:bg-orange-500/20 transition-colors">
                        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 8.5c1.38 0 2.5-1.34 2.5-3S13.38 2.5 12 2.5 9.5 3.84 9.5 5.5 10.62 8.5 12 8.5zm-5.5 1c1.1 0 2-1.12 2-2.5S7.6 4.5 6.5 4.5s-2 1.12-2 2.5 0.9 2.5 2 2.5zm11 0c1.1 0 2-1.12 2-2.5s-0.9-2.5-2-2.5-2 1.12-2 2.5 0.9 2.5 2 2.5zM4 13c1.1 0 2-1.12 2-2.5S5.1 8 4 8s-2 1.12-2 2.5S2.9 13 4 13zm16 0c1.1 0 2-1.12 2-2.5S21.1 8 20 8s-2 1.12-2 2.5 0.9 2.5 2 2.5zm-3.5 3.5c0-2.5-2-4.5-4.5-4.5s-4.5 2-4.5 4.5c0 2 1.5 3.5 3 4 1.5 0.5 1.5 1.5 1.5 1.5s0-1 1.5-1.5c1.5-0.5 3-2 3-4z"/>
                        </svg>
                    </div>
                    <h3 class="font-display text-2xl md:text-3xl font-bold text-slate-50 mb-2">
                        PASY - Plataforma de Adopción de Mascotas
                    </h3>
                    <p class="text-orange-400 font-medium mb-4">
                        Desarrollo Full-Stack con Python (Django)
                    </p>
                    <p class="text-slate-400 leading-relaxed mb-6">
                        Co-desarrollé una plataforma web completa para conectar albergues de animales con adoptantes, manejando tanto el frontend como el backend.
                    </p>
                    <div class="mt-auto flex items-center justify-between">
                        <a
                            href="https://github.com/beichooo/pasy-mascotas-project.git"
                            target="_blank"
                            class="bg-slate-800 text-slate-200 border border-slate-700 font-semibold py-2 px-4 rounded-lg text-sm hover:border-sky-400/60 hover:text-sky-400 transition-colors duration-300 inline-flex items-center"
                        >
                            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.168 6.839 9.492.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.031-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.03 1.595 1.03 2.688 0 3.848-2.338 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.001 10.001 0 0022 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd"></path></svg>
                            Ver Código
                        </a>
                    </div>
                </div>
                <!-- Proyecto Generador de Descripciones -->
                <div class="md:col-span-2 md:row-span-1 group relative bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden flex flex-col p-7 md:p-8 transition-all duration-300 hover:border-orange-500/50 hover:-translate-y-1 reveal reveal-delay-1">
