                <!-- Spotlight: Premiere Pro Cert -->
                <div class="md:col-span-2 md:row-span-1 bg-gradient-to-br from-slate-900 to-slate-900/50 border border-slate-800 rounded-2xl p-6 flex flex-col justify-center transition-all duration-300 hover:border-sky-400/50 reveal reveal-delay-2">
                    <div class="flex items-center mb-2">
                        <svg class="w-6 h-6 text-sky-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-xs font-semibold text-sky-400 uppercase tracking-wider">Certificado</span>
                    </div>
                    <p class="font-display text-2xl md:text-3xl font-bold text-slate-50 leading-tight">
                        Adobe Premiere Pro
                    </p>
                </div>
            </div>
        </section>

        <!-- Sección de Experiencia en Marketing -->
        <section id="case-studies" class="py-20">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-slate-50 mb-12 reveal">
